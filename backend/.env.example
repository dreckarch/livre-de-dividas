# Copie este arquivo para ".env" (mesma pasta) e ajuste os valores.
# ".env" nunca é versionado no Git (veja .gitignore).

# Nome exato do modelo que você baixou no Ollama.
# Rode `ollama list` no terminal pra ver os modelos disponíveis.
# Exemplos comuns: llama3.1, llama3.2, mistral, qwen2.5
OLLAMA_MODEL=llama3.2

# Endereço do servidor do Ollama. O padrão já funciona na grande maioria
# das instalações — só mude se você configurou o Ollama em outra porta/host.
OLLAMA_HOST=http://localhost:11434
